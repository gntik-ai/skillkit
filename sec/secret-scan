#!/usr/bin/env bash
#
# secret-scan — Buscar secretos filtrados con gitleaks o trufflehog.
#
# Auto-detecta la herramienta disponible (gitleaks preferido) o se fuerza con
# --tool. Escanea el working tree por defecto, o el historial git completo con
# --git-history.
#
# Convenciones del repo:
#   - la ayuda y los errores de uso funcionan sin la herramienta
#   - --dry-run muestra el comando exacto sin ejecutarlo (no requiere la herramienta)
#   - el informe va por stdout; resumen y mensajes por stderr
#   - exit: 0 sin hallazgos · 1 se encontraron secretos · 2 uso incorrecto ·
#     127 no hay ninguna herramienta de escaneo
#
# Flags concretos: gitleaks v8 / trufflehog v3.

set -euo pipefail

usage() {
  cat <<'EOF'
secret-scan — Buscar secretos filtrados (gitleaks o trufflehog).

Uso:
  secret-scan [RUTA] [--git-history] [--tool gitleaks|trufflehog]
              [--only-verified] [--json] [--dry-run]

Opciones:
      --git-history     Escanear todo el historial git (def.: working tree)
      --tool T          Forzar 'gitleaks' o 'trufflehog' (def.: autodetección)
      --only-verified   Solo hallazgos verificados (trufflehog)
      --json            Salida en JSON / JSONL de la herramienta
      --dry-run         Mostrar el comando sin ejecutarlo
  -h, --help            Esta ayuda

Salida: exit 0 si no hay secretos, exit 1 si los hay (apto para CI).

Ejemplos:
  secret-scan .                        # working tree con la herramienta disponible
  secret-scan . --git-history --json   # historial completo, salida JSON
  secret-scan src --tool trufflehog --only-verified
EOF
}

err() { echo "[secret-scan] $*" >&2; }

for arg in "$@"; do case "$arg" in -h|--help) usage; exit 0 ;; esac; done

TARGET="."
GIT_HISTORY=0
TOOL=""
ONLY_VERIFIED=0
JSON=0
DRY=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --git-history)   GIT_HISTORY=1; shift ;;
    --tool)          TOOL="$2"; shift 2 ;;
    --only-verified) ONLY_VERIFIED=1; shift ;;
    --json)          JSON=1; shift ;;
    --dry-run)       DRY=1; shift ;;
    -*)              err "opción desconocida: $1"; exit 2 ;;
    *)               TARGET="$1"; shift ;;
  esac
done

# 1) Validación de uso (exit 2).
case "${TOOL:-auto}" in
  auto|gitleaks|trufflehog) ;;
  *) err "--tool debe ser 'gitleaks' o 'trufflehog'"; exit 2 ;;
esac
if [[ "$DRY" -eq 0 && ! -e "$TARGET" ]]; then
  err "error: la ruta no existe: $TARGET"; exit 2
fi

# Selección de herramienta (para --dry-run prefiere gitleaks aunque no esté instalada).
select_tool() {
  if [[ -n "$TOOL" ]]; then echo "$TOOL"; return; fi
  if command -v gitleaks   >/dev/null 2>&1; then echo gitleaks;   return; fi
  if command -v trufflehog >/dev/null 2>&1; then echo trufflehog; return; fi
  echo ""
}
CHOSEN="$(select_tool)"
[[ -z "$CHOSEN" && "$DRY" -eq 1 ]] && CHOSEN="gitleaks"

# Construir el comando elegido en un array.
declare -a CMD=()
build_cmd() {
  if [[ "$CHOSEN" == "gitleaks" ]]; then
    # v8: 'detect' recorre el historial; --no-git limita al working tree.
    CMD=(gitleaks detect --source "$TARGET" --redact --exit-code 1)
    [[ "$GIT_HISTORY" -eq 0 ]] && CMD+=(--no-git)
    if [[ "$JSON" -eq 1 ]]; then CMD+=(--report-format json --report-path /dev/stdout)
    else CMD+=(--report-format json --report-path /dev/null --verbose); fi
  else  # trufflehog v3
    if [[ "$GIT_HISTORY" -eq 1 ]]; then CMD=(trufflehog git "file://${TARGET}")
    else CMD=(trufflehog filesystem "$TARGET"); fi
    CMD+=(--fail)
    [[ "$ONLY_VERIFIED" -eq 1 ]] && CMD+=(--only-verified)
    [[ "$JSON" -eq 1 ]] && CMD+=(--json)
  fi
  return 0
}
build_cmd

if [[ "$DRY" -eq 1 ]]; then
  err "[dry-run] ${CMD[*]}"
  exit 0
fi

# 2) Herramienta disponible (exit 127).
command -v "$CHOSEN" >/dev/null 2>&1 || {
  err "error: '$CHOSEN' no está instalado (instala gitleaks o trufflehog)"; exit 127; }

# Ejecutar. Ambas devuelven !=0 cuando hay hallazgos → lo mapeamos a exit 1.
RC=0
"${CMD[@]}" || RC=$?
if [[ "$RC" -eq 0 ]]; then
  err "sin secretos detectados"
  exit 0
fi
err "se detectaron posibles secretos (revisa la salida)"
exit 1
